// =============================================
// Initialize Gallery
// =============================================
function initGallery() {
  galleryGrid.innerHTML = '';
  const activeCat = document.querySelector('.cat-btn.active')?.dataset.cat || '莆仙戏';
  
  // 按分类顺序排列：莆仙戏→歌仔戏→小品→相声→电视剧→音乐→电影
  const catOrder = ['莆仙戏', '歌仔戏', '南音', '木偶戏', '电视剧', '音乐', '电影'];
  const sorted = [...operaDB].sort((a, b) => {
    const ai = catOrder.indexOf(a.category);
    const bi = catOrder.indexOf(b.category);
    return ai - bi;
  });
  
  sorted.forEach(opera => {
    if (opera.hidden) return;
    if (activeCat !== 'all' && opera.category !== activeCat) return;
    
    const item = document.createElement('div');
    item.className = 'gallery-item';
    
    const imgHtml = opera.poster 
      ? `<img src="${opera.poster}" alt="${opera.title}" onerror="this.outerHTML='<div style=\\'width:100%;aspect-ratio:16/9;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,${getCategoryGradient(opera.category)});border-radius:10px 10px 0 0;font-size:2em;\\'>${getCategoryEmoji(opera.category)}</div>'" />`
      : `<div style="width:100%;aspect-ratio:16/9;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,${getCategoryGradient(opera.category)});border-radius:10px 10px 0 0;font-size:2em;">${getCategoryEmoji(opera.category)}</div>`;
    
    item.innerHTML = `${imgHtml}<button class="item-play-btn" title="点播" data-opera-id="${opera.id || opera.title}">&#9654;</button><div class="item-title">${opera.title}</div>`;
    item.addEventListener('click', () => {
      currentOpera = opera;
      startPlayback(opera);
    });
    galleryGrid.appendChild(item);
  });

  // 点播按钮点击事件委托
  document.getElementById('galleryGrid').addEventListener('click', function(e) {
    var btn = e.target.closest('.item-play-btn');
    if (btn) {
      e.stopPropagation();
      var operaId = btn.getAttribute('data-opera-id');
      var opera = operaDB.find(function(o) { return (o.id || o.title) === operaId; });
      if (opera) {
        currentOpera = opera;
        startPlayback(opera);
      }
    }
  });
}

function getCategoryGradient(cat) {
  const gradients = {
    '莆仙戏': '#4a1010, #7a2020',
    '歌仔戏': '#1a3a5a, #2a5a8a',
    '小品': '#3a2a10, #6a4a20',
    '相声': '#1a2a3a, #3a4a5a',
    '电视剧': '#2a1a3a, #5a3a6a',
    '音乐': '#0a3a2a, #1a6a4a',
    '电影': '#3a1a1a, #6a2a2a',
  };
  return gradients[cat] || '#2a2a2a, #4a4a4a';
}

function getCategoryEmoji(cat) {
  const emojis = {
    '莆仙戏': '&#127917;',
    '歌仔戏': '&#127917;',
    '小品': '&#129323;',
    '相声': '&#128483;',
    '电视剧': '&#128247;',
    '音乐': '&#127925;',
    '电影': '&#127916;',
  };
  return emojis[cat] || '&#127916;';
}

