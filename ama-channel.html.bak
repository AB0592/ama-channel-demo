function escapeHtml(text) {
  return String(text || '').replace(/[&<>"']/g, function(ch) {
    return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[ch];
  });
}

function getSpeechRecognitionCtor() {
  return window.SpeechRecognition || window.webkitSpeechRecognition || null;
}

function getSpeechErrorMessage(error) {
  var code = error && error.error ? error.error : error;
  if (code === 'no-speech') return '没有听到声音，请靠近一点再试一次';
  if (code === 'not-allowed' || code === 'service-not-allowed') return '请允许使用麦克风（点击地址栏左侧锁图标开启）';
  if (code === 'audio-capture') return '找不到麦克风，请检查设备或系统输入权限';
  if (code === 'network') return '浏览器语音服务网络不可用，请稍后重试或直接打字输入';
  if (code === 'aborted') return '语音识别已取消';
  return '语音识别出错' + (code ? '（' + code + '）' : '') + '，请直接打字输入';
}

let activeSpeechRecognizer = null;

function stopOtherSpeechRecognizer(nextRecognizer) {
  if (activeSpeechRecognizer && activeSpeechRecognizer !== nextRecognizer) {
    try { activeSpeechRecognizer.stop(); } catch(e) {}
  }
  activeSpeechRecognizer = nextRecognizer || null;
}

function startSpeechRecognizer(recognizer, onFailure) {
  stopOtherSpeechRecognizer(recognizer);
  try {
    recognizer.start();
  } catch(e) {
    if (e && e.name === 'InvalidStateError') {
      try {
        recognizer.stop();
        setTimeout(function() {
          try {
            stopOtherSpeechRecognizer(recognizer);
            recognizer.start();
          } catch(e2) {
            onFailure(e2);
          }
        }, 200);
      } catch(e2) {
        onFailure(e2);
      }
      return;
    }
    onFailure(e);
  }
}

const FUNASR_DEFAULT_WS_URL = 'ws://127.0.0.1:10095';
let funasrSession = null;

function getFunasrWsUrl() {
  return localStorage.getItem('funasrWsUrl') || FUNASR_DEFAULT_WS_URL;
}

function buildFunasrHotwords() {
  var hotwords = {};
  if (typeof operaDB !== 'undefined') {
    operaDB.forEach(function(opera) {
      if (!opera.hidden && opera.title) hotwords[opera.title] = 30;
      (opera.keywords || []).forEach(function(keyword) {
        if (keyword) hotwords[keyword] = 20;
      });
    });
  }
  Object.keys(minnanDict || {}).forEach(function(key) {
    hotwords[key] = 25;
    hotwords[minnanDict[key]] = 25;
  });
  return JSON.stringify(hotwords);
}

function downsampleTo16k(float32Buffer, inputSampleRate) {
  var outputSampleRate = 16000;
  if (inputSampleRate === outputSampleRate) return float32Buffer;
  var ratio = inputSampleRate / outputSampleRate;
  var outputLength = Math.floor(float32Buffer.length / ratio);
  var output = new Float32Array(outputLength);
  for (var i = 0; i < outputLength; i++) {
    var start = Math.floor(i * ratio);
    var end = Math.floor((i + 1) * ratio);
    var sum = 0;
    var count = 0;
    for (var j = start; j < end && j < float32Buffer.length; j++) {
      sum += float32Buffer[j];
      count++;
    }
    output[i] = count ? sum / count : 0;
  }
  return output;
}

function floatToPcm16(float32Buffer) {
  var buffer = new ArrayBuffer(float32Buffer.length * 2);
  var view = new DataView(buffer);
  for (var i = 0; i < float32Buffer.length; i++) {
    var sample = Math.max(-1, Math.min(1, float32Buffer[i]));
    view.setInt16(i * 2, sample < 0 ? sample * 0x8000 : sample * 0x7fff, true);
  }
  return buffer;
}

function stopFunasrRecognition(options) {
  options = options || {};
  if (!funasrSession) return;
  var session = funasrSession;
  funasrSession = null;
  try {
    if (session.processor) session.processor.disconnect();
    if (session.source) session.source.disconnect();
    if (session.stream) session.stream.getTracks().forEach(function(track) { track.stop(); });
    if (session.ws && session.ws.readyState === WebSocket.OPEN) {
      session.ws.send(JSON.stringify({ is_speaking: false }));
      if (options.close !== false) setTimeout(function() { try { session.ws.close(); } catch(e) {} }, 300);
    }
    if (session.audioContext) session.audioContext.close();
  } catch(e) {}
  _isRecognizing = false;
  micBtn.classList.remove('listening');
  micBtn.innerHTML = '&#127908;<span class="ripple"></span>';
}

function startFunasrMinnanRecognition() {
  if (funasrSession) {
    stopFunasrRecognition();
    return;
  }
  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia || !window.WebSocket) {
    showStatus('result', '当前浏览器无法连接 FunASR，请使用 Chrome / Edge 或直接打字输入');
    return;
  }

  var wsUrl = getFunasrWsUrl();
  var ws;
  try {
    ws = new WebSocket(wsUrl);
  } catch(e) {
    showStatus('result', 'FunASR 地址无效：' + escapeHtml(wsUrl));
    return;
  }

  var finalText = '';
  var lastText = '';
  var startedAudio = false;
  _isRecognizing = true;
  micBtn.classList.add('listening');
  micBtn.innerHTML = '&#9724; 停止';
  showStatus('listening', '正在连接 FunASR 闽南语识别...');

  funasrSession = { ws: ws };

  ws.onopen = function() {
    var config = {
      mode: '2pass',
      chunk_size: [5, 10, 5],
      chunk_interval: 10,
      wav_name: 'ama-channel-minnan',
      is_speaking: true,
      hotwords: buildFunasrHotwords(),
      itn: true
    };
    var funasrLanguage = localStorage.getItem('funasrLanguage');
    if (funasrLanguage) config.language = funasrLanguage;
    ws.send(JSON.stringify(config));
    showStatus('listening', 'FunASR 已连接，正在听闽南话...');

    navigator.mediaDevices.getUserMedia({ audio: true })
      .then(function(stream) {
        if (!funasrSession || funasrSession.ws !== ws) {
          stream.getTracks().forEach(function(track) { track.stop(); });
          return;
        }
        var AudioContextCtor = window.AudioContext || window.webkitAudioContext;
        var audioContext = new AudioContextCtor();
        var source = audioContext.createMediaStreamSource(stream);
        var processor = audioContext.createScriptProcessor(4096, 1, 1);
        funasrSession.stream = stream;
        funasrSession.audioContext = audioContext;
        funasrSession.source = source;
        funasrSession.processor = processor;
        startedAudio = true;

        processor.onaudioprocess = function(event) {
          if (!funasrSession || funasrSession.ws !== ws || ws.readyState !== WebSocket.OPEN) return;
          var input = event.inputBuffer.getChannelData(0);
          var pcm = floatToPcm16(downsampleTo16k(input, audioContext.sampleRate));
          ws.send(pcm);
        };
        source.connect(processor);
        processor.connect(audioContext.destination);
      })
      .catch(function(err) {
        showStatus('result', '无法访问麦克风：' + escapeHtml(err.message || err));
        stopFunasrRecognition();
      });
  };

  ws.onmessage = function(event) {
    var data;
    try { data = JSON.parse(event.data); } catch(e) { return; }
    var text = String(data.text || data.result || '').trim();
    if (!text) return;
    lastText = text;
    if (data.mode === '2pass-offline' || data.is_final || data.is_final === true) {
      finalText = text;
    }
    userInput.value = finalText || lastText;
    userInput.style.color = '';
    showStatus('result', 'FunASR 识别结果：' + escapeHtml(userInput.value));
  };

  ws.onerror = function() {
    showStatus('result', '无法连接 FunASR 服务：' + escapeHtml(wsUrl) + '<br><span style="font-size:0.95em;color:var(--text-muted);">请确认 FunASR-Realtime 已启动，或用 localStorage.setItem("funasrWsUrl", "ws://你的地址") 修改地址。</span>');
    stopFunasrRecognition({ close: false });
  };

  ws.onclose = function() {
    var text = (finalText || lastText || userInput.value || '').trim();
    stopFunasrRecognition({ close: false });
    if (text) {
      userInput.value = text;
      showStatus('result', 'FunASR 最终结果：' + escapeHtml(text));
      setTimeout(startSearch, 500);
    } else if (startedAudio) {
      showStatus('result', 'FunASR 未返回识别结果，请再试一次或直接打字输入');
    }
  };
}

// =============================================
// Speech Recognition
// =============================================
function initSpeechRecognition() {
  const SpeechRecognition = getSpeechRecognitionCtor();
  if (!SpeechRecognition) {
    micBtn.title = '当前浏览器不支持语音识别，点击将播放推荐节目';
    langHint.textContent = '语音不可用，点击麦克风播放推荐';
    micBtn.addEventListener('click', function playDefault() {
      var defaultOpera = operaDB.find(function(o) { return o.title === '春草闯堂'; });
      if (defaultOpera) {
        showStatus('result', '语音识别不可用，已为您播放《春草闯堂》。');
        currentOpera = defaultOpera;
        startPlayback(defaultOpera);
      }
    }, { once: true });
    return;
  }

  recognition = new SpeechRecognition();
  recognition.continuous = false;
  recognition.interimResults = true;
  recognition.maxAlternatives = 3;

  recognition.onresult = function(event) {
    var transcript = '';
    var isFinal = false;
    for (var i = event.resultIndex; i < event.results.length; i++) {
      transcript += event.results[i][0].transcript;
      if (event.results[i].isFinal) isFinal = true;
    }
    userInput.value = transcript;
    userInput.style.color = '';

    var pinyinApprox = toPinyinApprox(transcript);
    if (pinyinApprox && transcript.trim()) {
      showStatus('result', '识别结果：' + escapeHtml(transcript) + '<br><span style="font-size:1.05em;color:var(--text-muted);">拼音近似：' + escapeHtml(pinyinApprox) + '</span>');
    }

    if (isFinal && transcript.trim()) {
      micBtn.classList.remove('listening');
      clearTimeout(window._recogTimeout);

      var translated = transcript;
      var changed = false;
      if (currentLang === 'puxianhua') {
        var sortedKeys = Object.keys(puxianDict).sort(function(a, b) { return b.length - a.length; });
        for (var k = 0; k < sortedKeys.length; k++) {
          var key = sortedKeys[k];
          if (translated.indexOf(key) !== -1) {
            translated = translated.split(key).join(puxianDict[key]);
            if (puxianDict[key] !== key) changed = true;
          }
        }
      } else if (currentLang === 'minnanhua') {
        var sortedKeys2 = Object.keys(minnanDict).sort(function(a, b) { return b.length - a.length; });
        for (var k2 = 0; k2 < sortedKeys2.length; k2++) {
          var key2 = sortedKeys2[k2];
          if (translated.indexOf(key2) !== -1) {
            translated = translated.split(key2).join(minnanDict[key2]);
            if (minnanDict[key2] !== key2) changed = true;
          }
        }
      }
      if (changed) {
        showStatus('result', '识别结果：' + escapeHtml(transcript) + '<br><span style="font-size:1.05em;color:var(--accent-green,#2E7D32);">方言翻译：' + escapeHtml(translated) + '</span><br><span style="font-size:1.05em;color:var(--text-muted,#7A6B5D);">拼音近似：' + escapeHtml(pinyinApprox) + '</span>');
      }

      setTimeout(function() {
        try { recognition.stop(); } catch(e) {}
        startSearch();
      }, 1200);
    }
  };

  recognition.onstart = function() {
    _isRecognizing = true;
    activeSpeechRecognizer = recognition;
    micBtn.classList.add('listening');
    if (currentLang === 'chinese') {
      showStatus('listening', '正在听您说话（中文模式）...');
    } else {
      showStatus('listening', '正在听您说话（请用普通话读戏名）...');
    }
    clearTimeout(window._recogTimeout);
    window._recogTimeout = setTimeout(() => {
      try { recognition.stop(); } catch(e) {}
    }, 8000);
  };

  recognition.onend = function() {
    _isRecognizing = false;
    if (activeSpeechRecognizer === recognition) activeSpeechRecognizer = null;
    micBtn.classList.remove('listening');
    clearTimeout(window._recogTimeout);
    if (!userInput.value.trim()) {
      recogStatus.classList.remove('active');
      showStatus('result', '没有听清，请再试一次或直接打字输入');
    }
  };

  recognition.onerror = function(event) {
    _isRecognizing = false;
    if (activeSpeechRecognizer === recognition) activeSpeechRecognizer = null;
    micBtn.classList.remove('listening');
    clearTimeout(window._recogTimeout);
    if (event.error === 'no-speech') {
      showStatus('result', '没有听到声音，请再试一次');
    } else if (event.error === 'not-allowed') {
      showStatus('result', '请允许使用麦克风（点击地址栏左侧锁图标开启）');
    } else if (event.error === 'audio-capture') {
      showStatus('result', '找不到麦克风，请检查设备');
    } else if (event.error === 'network') {
      _voiceFallbackMode = true;
      // Auto play default: 春草闯堂
      var defaultOpera = operaDB.find(function(o) { return o.title === '春草闯堂'; });
      if (defaultOpera) {
        showStatus('result', '网络不可用，语音识别暂时无法使用。已为您播放《春草闯堂》。');
        setTimeout(function() {
          currentOpera = defaultOpera;
          startPlayback(defaultOpera);
        }, 800);
      } else {
        showStatus('result', '网络不可用，语音识别暂时无法使用。请直接打字输入或点击海报选台。');
      }
    } else {
      showStatus('result', getSpeechErrorMessage(event));
    }
  };

  // Timeout
  recognition.ontimeout = function() {
    _isRecognizing = false;
    micBtn.classList.remove('listening');
    showStatus('result', '识别超时，请再试一次或直接打字输入');
  };

  // Test if recognition actually works
  window._speechAvailable = true;
  recognition.onnomatch = function() {
    // no match, but recognition works
  };
}

// =============================================
// Smart Voice Input: try recognition, fallback to recording
// =============================================
let _voiceFallbackMode = false;
let _mediaRecorder = null;
let _recordedChunks = [];
let _testTimeout = null;
let _isRecognizing = false;
let _isRecording = false;
let _recordingAutoStopTimer = null;

micBtn.addEventListener('click', () => {
  if (currentLang === 'minnanhua') {
    startFunasrMinnanRecognition();
    return;
  }

  if (!recognition) {
    _voiceFallbackMode = true;
    startRecordingMode();
    return;
  }

  if (_isRecording) {
    stopRecordingMode();
    return;
  }

  if (_voiceFallbackMode) {
    startRecordingMode();
    return;
  }

  if (_isRecognizing) {
    try { recognition.stop(); } catch(e) {}
    return;
  }

  // Set language based on current selection
  if (currentLang === 'chinese') {
    recognition.lang = 'zh-CN';
  } else if (currentLang === 'minnanhua') {
    recognition.lang = 'zh-CN'; // 闽南话也用中文识别引擎
  } else {
    recognition.lang = 'zh-CN';
  }

  startSpeechRecognizer(recognition, function() {
    showStatus('result', '语音识别启动失败，请检查麦克风权限，或直接打字输入');
  });
});

function startRecordingMode() {
  if (_isRecording) return;
  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia || !window.MediaRecorder) {
    showStatus('result', '当前浏览器无法语音识别或录音，请使用 Chrome / Edge，或直接打字输入节目名');
    return;
  }

  _isRecording = true;
  micBtn.classList.add('listening');
  micBtn.innerHTML = '&#9724; 停止';
  showStatus('listening', '正在录音，请直接说节目名，5秒后自动结束...');

  navigator.mediaDevices.getUserMedia({ audio: true })
    .then(stream => {
      _recordedChunks = [];
      _mediaRecorder = new MediaRecorder(stream);

      _mediaRecorder.ondataavailable = function(e) {
        if (e.data.size > 0) _recordedChunks.push(e.data);
      };

      _mediaRecorder.onstop = function() {
        clearTimeout(_recordingAutoStopTimer);
        _recordingAutoStopTimer = null;
        stream.getTracks().forEach(t => t.stop());
        _isRecording = false;
        micBtn.classList.remove('listening');
        micBtn.innerHTML = '&#127908;<span class="ripple"></span>';

        if (_recordedChunks.length > 0) {
          const blob = new Blob(_recordedChunks, { type: 'audio/webm' });
          const url = URL.createObjectURL(blob);
          const audio = new Audio(url);
          audio.play();

          showStatus('result', '已录完并开始回放。当前浏览器不能把这段录音自动转成文字，请在输入框输入节目名后点播。');
          // Set a placeholder
          if (!userInput.value.trim()) {
            userInput.value = '（请在此输入您想看的节目名）';
            userInput.style.color = 'var(--text-muted)';
            userInput.addEventListener('focus', function handler() {
              if (userInput.value === '（请在此输入您想看的节目名）') {
                userInput.value = '';
                userInput.style.color = '';
              }
              userInput.removeEventListener('focus', handler);
            });
          }
        } else {
          showStatus('result', '录音失败，请直接打字输入');
        }
      };

      _mediaRecorder.start();
      _recordingAutoStopTimer = setTimeout(function() {
        stopRecordingMode();
      }, 5000);
    })
    .catch(err => {
      clearTimeout(_recordingAutoStopTimer);
      _recordingAutoStopTimer = null;
      _isRecording = false;
      micBtn.classList.remove('listening');
      micBtn.innerHTML = '&#127908;<span class="ripple"></span>';
      showStatus('result', '无法访问麦克风：' + err.message + '。请直接打字输入。');
    });
}

function stopRecordingMode() {
  clearTimeout(_recordingAutoStopTimer);
  _recordingAutoStopTimer = null;
  if (_mediaRecorder && _mediaRecorder.state === 'recording') {
    _mediaRecorder.stop();
  }
}

function showStatus(type, text) {
  recogStatus.className = 'recognition-status active ' + (type === 'listening' ? 'listening-status' : 'result-status');
  statusDot.className = type === 'listening' ? 'status-dot' : 'result-dot';
  statusText.innerHTML = text;
}

function setupDialectDictMic(options) {
  var button = document.getElementById(options.buttonId);
  var statusEl = document.getElementById(options.statusId);
  var dialectInput = document.getElementById(options.dialectInputId);
  var chineseInput = document.getElementById(options.chineseInputId);
  if (!button || !statusEl || !dialectInput) return;

  var SpeechRecognition = getSpeechRecognitionCtor();
  if (!SpeechRecognition) {
    button.style.opacity = '0.5';
    button.title = '此浏览器不支持语音识别';
    statusEl.textContent = '当前浏览器不支持语音识别，请手动输入发音';
    return;
  }

  var dictRecognition = new SpeechRecognition();
  var listening = false;
  dictRecognition.continuous = false;
  dictRecognition.interimResults = true;
  dictRecognition.maxAlternatives = 3;
  dictRecognition.lang = 'zh-CN';

  function setListening(on) {
    listening = on;
    button.classList.toggle('listening', on);
    button.style.background = on ? 'var(--gold)' : 'transparent';
    button.style.color = on ? '#fff' : 'var(--gold)';
  }

  button.addEventListener('click', function() {
    if (listening) {
      try { dictRecognition.stop(); } catch(e) {}
      return;
    }
    statusEl.textContent = '正在听您说话...';
    statusEl.style.color = 'var(--gold)';
    startSpeechRecognizer(dictRecognition, function() {
      setListening(false);
      statusEl.textContent = '语音识别启动失败，请手动输入发音';
      statusEl.style.color = '#FF6B6B';
    });
  });

  dictRecognition.onstart = function() {
    activeSpeechRecognizer = dictRecognition;
    setListening(true);
  };

  dictRecognition.onresult = function(event) {
    var transcript = '';
    var isFinal = false;
    for (var i = event.resultIndex; i < event.results.length; i++) {
      transcript += event.results[i][0].transcript;
      if (event.results[i].isFinal) isFinal = true;
    }
    transcript = transcript.trim();
    if (!transcript) return;

    // Apply dialect correction
    var corrected = transcript;
    var translated = transcript;
    var isPuxian = options.buttonId.indexOf('puxian') >= 0;
    if (isPuxian && typeof translatePuxian === 'function') {
      var pResult = translatePuxian(transcript);
      if (pResult.changed) translated = pResult.translated;
    } else if (!isPuxian && typeof translateMinnan === 'function') {
      var mResult = translateMinnan(transcript);
      if (mResult.changed) translated = mResult.translated;
    }
    corrected = normalizeSpokenQuery(translated);

    var pinyin = toPinyinApprox(transcript);
    dialectInput.value = transcript;
    statusEl.innerHTML = '识别结果：<strong>' + escapeHtml(transcript) + '</strong>' +
      (pinyin ? '<br><span style="font-size:0.9em;color:var(--text-muted);">拼音近似：' + escapeHtml(pinyin) + '</span>' : '') +
      (corrected !== transcript ? '<br><span style="font-size:0.9em;color:var(--accent-green,#2E7D32);">纠正后：' + escapeHtml(corrected) + '</span>' : '');
    statusEl.style.color = 'var(--text,#3D2914)';

    if (isFinal) {
      setListening(false);
      if (typeof searchOpera === 'function' && typeof operaDB !== 'undefined') {
        // Fuzzy search: try multiple candidates
        var matchResults = findBestVoiceMatches(transcript);
        if (matchResults.results.length > 0) {
          var topMatches = matchResults.results.slice(0, 3);
          if (chineseInput) chineseInput.value = topMatches[0].title;
          var matchList = topMatches.map(function(op) { return op.title; }).join('、');
          statusEl.innerHTML = '识别：<strong>' + escapeHtml(transcript) + '</strong>' +
            (pinyin ? '<br><span style="font-size:0.9em;color:var(--text-muted);">拼音：' + escapeHtml(pinyin) + '</span>' : '') +
            '<br><span style="color:var(--accent-green,#2E7D32);font-weight:bold;">匹配节目（' + matchResults.results.length + '个）：' + escapeHtml(matchList) + '</span>';
        } else {
          statusEl.innerHTML = '识别：<strong>' + escapeHtml(transcript) + '</strong>' +
            (pinyin ? '<br><span style="font-size:0.9em;color:var(--text-muted);">拼音：' + escapeHtml(pinyin) + '</span>' : '') +
            '<br><span style="color:var(--text-muted);font-size:0.9em;">未匹配到节目，请手动填写中文名称</span>';
        }
      }
    }
  };

  dictRecognition.onend = function() {
    if (activeSpeechRecognizer === dictRecognition) activeSpeechRecognizer = null;
    setListening(false);
  };

  dictRecognition.onerror = function(event) {
    if (activeSpeechRecognizer === dictRecognition) activeSpeechRecognizer = null;
    setListening(false);
    statusEl.textContent = getSpeechErrorMessage(event);
    statusEl.style.color = '#FF6B6B';
  };
}

// =============================================
// Search & Match (with Puxian Translation)
// =============================================
let originalInput = ''; // 保存原始方言输入

function startSearch() {
  const rawInput = userInput.value.trim();
  if (!rawInput) return;
  originalInput = rawInput;

  // 先停止任何正在播放的内容，清理状态
  stopCurrentPlayback();
  playerSection.classList.remove('active');
  isPlaying = false;

  const isChinese = (currentLang === 'chinese');
  currentOpera = null;

  // 显示翻译流程卡片
  resultSection.classList.remove('active');
  resultSection.removeAttribute('aria-modal');
  playerSection.classList.remove('active');
  confirmBtn.style.display = '';
  switchBtn.style.display = '';
  if (translationFlow) translationFlow.classList.add('active');

  // Step 1: 显示原始输入
  if (flowOriginal) { flowOriginal.innerHTML = rawInput; flowOriginal.className = 'flow-step-content original'; }

  if (isChinese) {
    // 中文模式：跳过翻译
    if (flowTranslated) { flowTranslated.innerHTML = '<span class="flow-no-translate">中文模式，无需翻译</span>'; flowTranslated.className = 'flow-step-content translated'; }
  } else if (currentLang === 'minnanhua') {
    // 闽南话模式：翻译
    const { translated, changed } = translateMinnan(rawInput);
    if (changed) {
      if (flowTranslated) flowTranslated.innerHTML = '<strong>' + translated + '</strong>';
    } else {
      if (flowTranslated) flowTranslated.innerHTML = '<span class="flow-no-translate">已是普通话，无需翻译</span>';
    }
    if (flowTranslated) flowTranslated.className = 'flow-step-content translated';
  } else {
    // 莆仙话模式：翻译
    const { translated, changed } = translatePuxian(rawInput);
    if (changed) {
      if (flowTranslated) flowTranslated.innerHTML = '<strong>' + translated + '</strong>';
    } else {
      if (flowTranslated) flowTranslated.innerHTML = '<span class="flow-no-translate">已是普通话，无需翻译</span>';
    }
    if (flowTranslated) flowTranslated.className = 'flow-step-content translated';
  }

  if (flowMatched) { flowMatched.innerHTML = '<span class="flow-no-translate">搜索中...</span>'; flowMatched.className = 'flow-step-content matched'; }

  loadingSpinner.classList.add('active');

  setTimeout(() => {
    const bestMatch = findBestVoiceMatches(rawInput);
    matchResults = bestMatch.results;
    currentMatchIndex = 0;

    if (matchResults.length > 0) {
      if (flowMatched) flowMatched.innerHTML = '<strong>' + matchResults[0].title + '</strong><br><span style="font-size:0.85em;color:var(--text-muted);">按“就是这个”播放</span>';
      if (bestMatch.query && bestMatch.query !== rawInput) {
        userInput.value = bestMatch.query;
      }
    } else {
      if (flowMatched) flowMatched.innerHTML = '<span class="flow-no-translate">未匹配到节目</span>';
    }

    loadingSpinner.classList.remove('active');

    // Check relevance: only show confirmation for meaningful matches
    if (matchResults.length > 0) {
      var sq = (bestMatch.query || rawInput).toLowerCase();
      var sBest = matchResults[0].title.toLowerCase();
      var sExact = sBest === sq || sBest.includes(sq) || sq.includes(sBest);
      var sLcs = 0;
      if (!sExact && sq.length > 0) {
        var sShort = Math.min(sq.length, sBest.length);
        var sm = sq.length, sn = sBest.length;
        var sp = new Array(sn+1).fill(0), sc = new Array(sn+1).fill(0);
        for (var si = 1; si <= sm; si++) { for (var sj = 1; sj <= sn; sj++) { if (sq[si-1]===sBest[sj-1]) sc[sj]=sp[sj-1]+1; else sc[sj]=Math.max(sp[sj],sc[sj-1]); } var st=sp;sp=sc;sc=st; for(var sk=0;sk<=sn;sk++)sc[sk]=0; }
        sLcs = sp[sn] / sShort;
      }
      if (sExact || sLcs >= 0.5) {
        showResult();
      } else {
        if (flowMatched) flowMatched.innerHTML = '<span class="flow-no-translate">未找到相关节目</span>';
        if (translationFlow) translationFlow.classList.remove('active');
        showStatus('result', '未找到「' + escapeHtml(rawInput) + '」相关的节目。请试试说出戏名，如"春草闯堂"，或点击下方海报直接选台。');
      }
    } else {
      if (flowMatched) flowMatched.innerHTML = '<span class="flow-no-translate">未匹配到节目</span>';
      if (translationFlow) translationFlow.classList.remove('active');
      showStatus('result', '未找到「' + escapeHtml(rawInput) + '」相关的节目。请试试说出戏名，如"春草闯堂"，或点击下方海报直接选台。');
    }
  }, isChinese ? 600 : 1000);
}

function longestCommonSubseq(a, b) {
  var m = a.length, n = b.length;
  var prev = new Array(n + 1).fill(0);
  var curr = new Array(n + 1).fill(0);
  for (var i = 1; i <= m; i++) {
    for (var j = 1; j <= n; j++) {
      if (a[i-1] === b[j-1]) curr[j] = prev[j-1] + 1;
      else curr[j] = Math.max(prev[j], curr[j-1]);
    }
    var tmp = prev; prev = curr; curr = tmp;
    for (var k = 0; k <= n; k++) curr[k] = 0;
  }
  return prev[n];
}

function searchOpera(query) {
  if (!query || !query.trim()) return [];
  var q = query.toLowerCase();
  var results = [];

  operaDB.forEach(function(opera) {
    if (opera.hidden) return;
    var score = 0;
    var title = opera.title;
    var titleLower = title.toLowerCase();

    // Exact title match
    if (title === query) score += 100;
    // Title contains query or vice versa
    else if (titleLower.includes(q) || q.includes(titleLower)) score += 50;

    // LCS fuzzy match on title
    var lcsLen = longestCommonSubseq(q, titleLower);
    var shorter = Math.min(q.length, titleLower.length);
    if (shorter > 0 && lcsLen / shorter >= 0.4) {
      score += Math.round(lcsLen / shorter * 60);
    }

    // Description keyword match
    if (opera.description) {
      var descLower = opera.description.toLowerCase();
      if (descLower.includes(q)) score += 15;
      var lcsDesc = longestCommonSubseq(q, descLower);
      if (lcsDesc >= 3) score += 10;
    }

    // Category fuzzy match
    var catLower = (opera.category || '').toLowerCase();
    if (catLower.includes(q) || q.includes(catLower)) score += 8;

    // Keyword matching
    (opera.keywords || []).forEach(function(kw) {
      var kwLower = kw.toLowerCase();
      if (kwLower === q) score += 40;
      else if (kwLower.includes(q) || q.includes(kwLower)) score += 20;
      var lcsKw = longestCommonSubseq(q, kwLower);
      if (lcsKw >= 2) score += lcsKw * 5;
    });

    if (score > 0) results.push({ opera: opera, score: score });
  });

  results.sort(function(a, b) { return b.score - a.score; });
  return results.map(function(r) { return r.opera; });
}

function showResult() {
  currentOpera = matchResults[currentMatchIndex];
  if (!currentOpera) {
    showNoResult();
    return;
  }
  const selectedOpera = currentOpera;

  confirmBtn.style.display = '';
  switchBtn.style.display = matchResults.length > 1 ? '' : 'none';

  if (selectedOpera.poster) {
    resultPoster.onerror = function() {
      resultPoster.onerror = null;
      resultPoster.src = generatePoster(selectedOpera.title, selectedOpera.category, '#4a1010', '#B87520');
      resultPoster.style.display = 'block';
      resultPosterFallback.style.display = 'none';
    };
    resultPoster.src = selectedOpera.poster;
    resultPoster.style.display = 'block';
    resultPosterFallback.style.display = 'none';
  } else {
    resultPoster.onerror = null;
    resultPoster.src = generatePoster(selectedOpera.title, selectedOpera.category, '#4a1010', '#B87520');
    resultPoster.style.display = 'block';
    resultPosterFallback.style.display = 'none';
  }
  resultTitle.textContent = selectedOpera.title;
  resultDesc.textContent = selectedOpera.description;
  matchIndex.textContent = `(${currentMatchIndex + 1}/${matchResults.length})`;

  resultSection.classList.add('active');
  resultSection.removeAttribute('aria-modal');
  setTimeout(function() {
    resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    confirmBtn.focus({ preventScroll: true });
  }, 50);
}

function showNoResult() {
  currentOpera = null;
  resultSection.classList.add('active');
  resultSection.removeAttribute('aria-modal');
  resultPoster.src = 'data:image/svg+xml,' + encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" width="400" height="260" fill="none"><rect width="400" height="260" fill="%231A0A00"/><text x="200" y="120" text-anchor="middle" fill="%23D4A853" font-size="40">&#128533;</text><text x="200" y="160" text-anchor="middle" fill="%23B89878" font-size="18" font-family="sans-serif">没有找到这出戏</text><text x="200" y="185" text-anchor="middle" fill="%23888888" font-size="14" font-family="sans-serif">请试试说出戏名或关键词</text></svg>');
  resultPoster.style.display = 'block';
  resultPosterFallback.style.display = 'none';
  resultTitle.textContent = '没有找到匹配的戏目';
  resultDesc.textContent = '试试说出戏名，比如"春草闯堂"、"状元与乞丐"。也可以点击下方"戏曲精选"直接选择。';
  matchIndex.textContent = '';
  confirmBtn.style.display = 'none';
  switchBtn.style.display = 'none';
  setTimeout(function() {
    resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 50);
}

function getDisplayPoster(opera) {
  return opera.poster || generatePoster(opera.title, opera.category, '#4a1010', '#B87520');
}

// =============================================
// Player
// =============================================
let audioElement = null;
let useRealAudio = false;

function stopCurrentPlayback() {
  if (audioElement) {
    audioElement.pause();
    audioElement.currentTime = 0;
    // Remove all event listeners by replacing with a clone
    try {
      var clone = audioElement.cloneNode(true);
      clone.src = '';
      if (audioElement.parentNode) {
        audioElement.parentNode.replaceChild(clone, audioElement);
      }
    } catch(e) {
      // fallback: just null out
    }
    audioElement = null;
  }
  if (window._demoInterval) {
    clearInterval(window._demoInterval);
    window._demoInterval = null;
  }
  // Clear player display
  if (typeof playerDisplay !== 'undefined' && playerDisplay) {
    playerDisplay.innerHTML = '';
  }
}

function startPlayback(opera) {
  stopCurrentPlayback();
  resultSection.classList.remove('active');
  resultSection.removeAttribute('aria-modal');
  playerSection.classList.add('active');
  playerTitle.textContent = opera.title;

  if (opera.media) {
    useRealAudio = true;
    renderRealAudioPlayer(opera);
  } else {
    useRealAudio = false;
    isPlaying = true;
    updatePlayPauseIcon();
    renderDemoPlayer(opera);
  }
}

function renderRealAudioPlayer(opera) {
  // Clear subtitles
  subtitleText.classList.add('hidden');
  subtitleText.textContent = '';

  // Check if media is a video file
  const isVideo = /\.(mp4|webm|ogg)$/i.test(opera.media);

  if (isVideo) {
    // Video playback mode
    playerDisplay.innerHTML = `<video id="videoPlayer" playsinline style="width:100%;height:100%;object-fit:contain;background:#000;"></video>`;
    audioElement = document.getElementById('videoPlayer');
    audioElement.src = opera.media;
  } else {
    // Audio playback mode
    playerDisplay.innerHTML = `
      <div class="audio-visual">
        <img class="opera-poster-display" src="${getDisplayPoster(opera)}" alt="${opera.title}" onerror="this.src='${generatePoster(opera.title, opera.category, '#4a1010', '#B87520')}'" />
        <div class="eq-bars" id="eqBars">
          <div class="bar"></div><div class="bar"></div><div class="bar"></div>
          <div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div>
        </div>
        <div class="title-display">${opera.title}</div>
      </div>
    `;
    audioElement = new Audio(opera.media);
  }

  audioElement.volume = volumeSlider.value / 100;

  audioElement.addEventListener('loadedmetadata', onAudioLoaded);
  audioElement.addEventListener('timeupdate', onAudioTimeUpdate);
  audioElement.addEventListener('ended', onAudioEnded);

  audioElement.play().then(() => {
    isPlaying = true;
    updatePlayPauseIcon();
  }).catch(err => {
    console.warn('Audio autoplay blocked:', err);
    isPlaying = false;
    updatePlayPauseIcon();
  });

  function formatTime(s) {
    if (isNaN(s)) return '00:00';
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60);
    return String(m).padStart(2,'0') + ':' + String(sec).padStart(2,'0');
  }

  function onAudioLoaded() {
    totalTimeEl.textContent = formatTime(audioElement.duration);
    currentTimeEl.textContent = formatTime(0);
  }

  function onAudioTimeUpdate() {
    if (audioElement && audioElement.duration) {
      const pct = (audioElement.currentTime / audioElement.duration) * 100;
      progressFill.style.width = pct + '%';
      currentTimeEl.textContent = formatTime(audioElement.currentTime);

      // Subtitle sync
      if (opera.subtitles) {
        const t = audioElement.currentTime;
        let found = false;
        for (const sub of opera.subtitles) {
          if (t >= sub.start && t < sub.end) {
            subtitleText.textContent = sub.text;
            subtitleText.classList.remove('hidden');
            found = true;
            break;
          }
        }
        if (!found) {
          subtitleText.classList.add('hidden');
        }
      }
    }
  }

  function onAudioEnded() {
    isPlaying = false;
    updatePlayPauseIcon();
    progressFill.style.width = '100%';
    subtitleText.classList.add('hidden');
  }

  // Expose seek and reset for controls
  window._realAudioSeek = function(ratio) {
    if (audioElement && audioElement.duration) {
      audioElement.currentTime = ratio * audioElement.duration;
    }
  };
  window._realAudioRewind = function() {
    if (audioElement) audioElement.currentTime = Math.max(0, audioElement.currentTime - 10);
  };
  window._realAudioForward = function() {
    if (audioElement && audioElement.duration) audioElement.currentTime = Math.min(audioElement.duration, audioElement.currentTime + 10);
  };
  window._realAudioReplay = function() {
    if (audioElement) {
      audioElement.currentTime = 0;
      audioElement.play();
      isPlaying = true;
      updatePlayPauseIcon();
    }
  };
}

function renderDemoPlayer(opera) {
  playerDisplay.innerHTML = `
    <div class="audio-visual">
      <img class="opera-poster-display" src="${getDisplayPoster(opera)}" alt="${opera.title}" onerror="this.src='${generatePoster(opera.title, opera.category, '#4a1010', '#B87520')}'" />
      <div class="eq-bars" id="eqBars">
        <div class="bar"></div><div class="bar"></div><div class="bar"></div>
        <div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div>
      </div>
      <div class="title-display">${opera.title}</div>
      <div style="color: var(--text-muted); font-size: 0.85em; margin-top: 4px;">（Demo模式 · 等待音频文件接入）</div>
    </div>
  `;

  // Simulate a 90-second playback
  let elapsed = 0;
  const duration = 90;

  function formatTime(s) {
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60);
    return String(m).padStart(2,'0') + ':' + String(sec).padStart(2,'0');
  }

  totalTimeEl.textContent = formatTime(duration);

  if (window._demoInterval) clearInterval(window._demoInterval);

  function tick() {
    if (isPlaying) {
      elapsed += 0.3;
      if (elapsed >= duration) {
        elapsed = duration;
        isPlaying = false;
        updatePlayPauseIcon();
      }
      progressFill.style.width = (elapsed / duration * 100) + '%';
      currentTimeEl.textContent = formatTime(elapsed);
    }
  }

  window._demoInterval = setInterval(tick, 300);

  window._demoSeek = function(newElapsed) {
    elapsed = Math.max(0, Math.min(newElapsed, duration));
    progressFill.style.width = (elapsed / duration * 100) + '%';
    currentTimeEl.textContent = formatTime(elapsed);
  };

  window._demoReset = function() {
    elapsed = 0;
    isPlaying = true;
    updatePlayPauseIcon();
    const eqBars = document.getElementById('eqBars');
    if (eqBars) eqBars.classList.remove('paused');
    tick();
  };
}

function updatePlayPauseIcon() {
  btnPlayPause.innerHTML = isPlaying ? '&#9646;&#9646;' : '&#9654;';
  playingDot.className = isPlaying ? 'playing-dot' : 'playing-dot paused';
  const eqBars = document.getElementById('eqBars');
  if (eqBars) {
    eqBars.classList.toggle('paused', !isPlaying);
  }
}

// =============================================
// Event Listeners
// =============================================

// Mic button
// Search button
searchBtn.addEventListener('click', startSearch);

// Enter key
userInput.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') startSearch();
});

// Confirm - always close result section and start playback
confirmBtn.addEventListener('click', () => {
  const opera = currentOpera;
  resultSection.classList.remove('active');
  resultSection.removeAttribute('aria-modal');
  if (opera) startPlayback(opera);
});

resultSection.addEventListener('click', (e) => {
  if (e.target === resultSection) {
    resultSection.classList.remove('active');
    resultSection.removeAttribute('aria-modal');
  }
});

document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && resultSection.classList.contains('active')) {
    resultSection.classList.remove('active');
    resultSection.removeAttribute('aria-modal');
  }
});

// Switch
switchBtn.addEventListener('click', () => {
  if (!matchResults.length) {
    resultSection.classList.remove('active');
    resultSection.removeAttribute('aria-modal');
    return;
  }
  currentMatchIndex = (currentMatchIndex + 1) % matchResults.length;
  showResult();
});

// Play/Pause
btnPlayPause.addEventListener('click', () => {
  if (useRealAudio && audioElement) {
    if (isPlaying) {
      audioElement.pause();
    } else {
      audioElement.play();
    }
  }
  isPlaying = !isPlaying;
  updatePlayPauseIcon();
});

// Rewind
btnRewind.addEventListener('click', () => {
  if (useRealAudio && window._realAudioRewind) {
    window._realAudioRewind();
  } else if (window._demoSeek) {
    const current = parseFloat(progressFill.style.width) / 100 * 90;
    window._demoSeek(current - 10);
  }
});

// Forward
btnForward.addEventListener('click', () => {
  if (useRealAudio && window._realAudioForward) {
    window._realAudioForward();
  } else if (window._demoSeek) {
    const current = parseFloat(progressFill.style.width) / 100 * 90;
    window._demoSeek(current + 10);
  }
});

// Replay
btnReplay.addEventListener('click', () => {
  if (useRealAudio && window._realAudioReplay) {
    window._realAudioReplay();
  } else if (window._demoReset) {
    window._demoReset();
  }
});

// Progress bar click
progressWrap.addEventListener('click', (e) => {
  const rect = progressWrap.getBoundingClientRect();
  const ratio = (e.clientX - rect.left) / rect.width;
  if (useRealAudio && window._realAudioSeek) {
    window._realAudioSeek(ratio);
  } else if (window._demoSeek) {
    window._demoSeek(ratio * 90);
  }
});

// Volume
volumeSlider.addEventListener('input', () => {
  if (useRealAudio && audioElement) {
    audioElement.volume = volumeSlider.value / 100;
  }
});

// Back to select - properly reset all states
btnBackSelect.addEventListener('click', () => {
  stopCurrentPlayback();
  playerSection.classList.remove('active');
  isPlaying = false;
  currentOpera = null;
  matchResults = [];
  currentMatchIndex = 0;
  resultSection.classList.remove('active');
  resultSection.removeAttribute('aria-modal');
});

// =============================================
// Init
// =============================================
initGallery();

// Category tab click
document.querySelectorAll('.cat-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    initGallery();
  });
});

initSpeechRecognition();

// =============================================
// Scroll: hide topbar on scroll down, show on scroll up
// =============================================
(function() {
  var topbar = document.querySelector('.app-topbar');
  if (!topbar) return;
  var lastScrollY = window.scrollY;
  var ticking = false;

  function updateTopbar() {
    var currentY = window.scrollY;
    if (currentY > lastScrollY && currentY > 80) {
      topbar.classList.add('topbar-hidden');
    } else {
      topbar.classList.remove('topbar-hidden');
    }
    lastScrollY = currentY;
    ticking = false;
  }

  window.addEventListener('scroll', function() {
    if (!ticking) {
      requestAnimationFrame(updateTopbar);
      ticking = true;
    }
  }, { passive: true });
})();

// =============================================
// Voice Browse Mode (TTS-based)
// =============================================
const voiceBrowseBtn = document.getElementById('voiceBrowseBtn');
let browseOverlay = null;
let browseIndex = 0;
let browseList = [];
let isBrowsing = false;
let currentCategory = 'all';

voiceBrowseBtn.addEventListener('click', () => {
  // Get current category filter
  const activeCat = document.querySelector('.cat-btn.active')?.dataset.cat || '莆仙戏';
  currentCategory = activeCat;
  
  // 获取所有节目（不限分类），过滤隐藏条目
  const catOrder = ['莆仙戏', '歌仔戏', '南音', '木偶戏', '电视剧', '音乐', '电影'];
  browseList = operaDB.filter(opera => !opera.hidden);
  browseList.sort((a, b) => {
    const ai = catOrder.indexOf(a.category);
    const bi = catOrder.indexOf(b.category);
    return ai - bi;
  });
  
  if (browseList.length === 0) return;
  
  browseIndex = 0;
  isBrowsing = true;
  voiceBrowseBtn.classList.add('browsing');
  
  createBrowseOverlay();
  showBrowseItem();
});

function createBrowseOverlay() {
  browseOverlay = document.createElement('div');
  browseOverlay.className = 'voice-browse-overlay';
  browseOverlay.innerHTML = `
    <div class="voice-browse-card">
      <div class="voice-browse-poster-fallback" id="browsePoster"></div>
      <div class="voice-browse-current" id="browseTitle"></div>
      <div class="voice-browse-desc" id="browseDesc"></div>
      <div class="voice-browse-controls">
        <button class="vb-prev" id="vbPrev">&#9664; 上一个</button>
        <button class="vb-confirm" id="vbConfirm">&#9989; 就是这个！</button>
        <button class="vb-next" id="vbNext">下一个 &#9654;</button>
      </div>
      <div class="voice-browse-controls" style="margin-top:8px;">
        <button class="vb-close" id="vbClose">关闭</button>
      </div>
      <div class="voice-browse-counter" id="browseCounter"></div>
        <div style=\"text-align:center;font-size:0.72em;color:#999;margin-top:4px;\">&#9888; 语音为AI合成，仅供功能演示</div>
    </div>
  `;
  document.body.appendChild(browseOverlay);
  
  document.getElementById('vbPrev').addEventListener('click', () => {
    browseIndex = (browseIndex - 1 + browseList.length) % browseList.length;
    showBrowseItem();
  });
  document.getElementById('vbNext').addEventListener('click', () => {
    browseIndex = (browseIndex + 1) % browseList.length;
    showBrowseItem();
  });
  document.getElementById('vbConfirm').addEventListener('click', () => {
    const opera = browseList[browseIndex];
    closeBrowse();
    userInput.value = opera.title;
    startSearch();
  });
  document.getElementById('vbClose').addEventListener('click', closeBrowse);
}

function showBrowseItem() {
  const opera = browseList[browseIndex];
  const titleEl = document.getElementById('browseTitle');
  const descEl = document.getElementById('browseDesc');
  const posterEl = document.getElementById('browsePoster');
  const counterEl = document.getElementById('browseCounter');
  
  titleEl.textContent = opera.title;
  descEl.textContent = opera.description ? opera.description.substring(0, 50) + '...' : '';
  counterEl.textContent = `第 ${browseIndex + 1} / ${browseList.length} 个`;
  
  if (opera.poster) {
    posterEl.innerHTML = '';
    const img = document.createElement('img');
    img.src = opera.poster;
    img.alt = opera.title;
    img.style.cssText = 'width:180px;height:120px;border-radius:10px;object-fit:cover;';
    posterEl.appendChild(img);
    posterEl.style.display = 'flex';
  } else {
    posterEl.innerHTML = getCategoryEmoji(opera.category);
    posterEl.style.display = 'flex';
  }
  
  // TTS: speak the title
  speakTitle(opera.title);
}

function speakTitle(text) {
  // Cancel any ongoing speech
  window.speechSynthesis.cancel();
  
  const utterance = new SpeechSynthesisUtterance(text);
  utterance.lang = 'zh-CN';
  utterance.rate = 0.85;  // Slower for elderly
  utterance.pitch = 1.0;
  utterance.volume = 1.0;
  
  // Try to find a Chinese voice
  const voices = window.speechSynthesis.getVoices();
  const zhVoice = voices.find(v => v.lang.startsWith('zh'));
  if (zhVoice) utterance.voice = zhVoice;
  
  window.speechSynthesis.speak(utterance);
}

function closeBrowse() {
  isBrowsing = false;
  voiceBrowseBtn.classList.remove('browsing');
  window.speechSynthesis.cancel();
  if (browseOverlay) {
    browseOverlay.remove();
    browseOverlay = null;
  }
}


// Preload voices
if (window.speechSynthesis) {
  window.speechSynthesis.getVoices();
  window.speechSynthesis.onvoiceschanged = () => {
    window.speechSynthesis.getVoices();
  };
}

</script>

<!-- ===== About Modal ===== -->
<div class="about-modal-overlay hidden" id="aboutOverlay">
  <div class="about-modal">
    <h2>&#128250; 阿嬷的频道</h2>
    <p class="about-subtitle">让长辈不用学复杂手机操作，只要说句话，就能找到想看的原声节目</p>

    <h3>&#127919; 是什么</h3>
    <p>一个让<span class="highlight">阿嬷更容易找节目</span>的暖心网站。用户用方言说出想看的莆仙戏、歌仔戏、南音、木偶戏，或想听的经典歌曲、想看的电视剧和电影，系统自动理解意思，显示图片让用户确认，再播放原声内容。未来还可以扩展更多戏曲剧种和地方文艺节目。</p>

    <h3>&#10024; 创新点</h3>
    <div class="about-value-grid">
      <div class="about-value-card">
        <h4>&#127760; 方言成为入口</h4>
        <p>很多适老化产品只解决字体和按钮问题，但《阿嬷的频道》进一步关注老人真实的表达方式。长辈说不标准普通话、不会打字，都不应该成为他们使用数字内容的门槛。</p>
      </div>
      <div class="about-value-card">
        <h4>&#127917; 非遗连接日常</h4>
        <p>作品不是把非遗做成冷冰冰的资料库，而是把它放回长辈日常生活中。阿嬷可以看戏、听南音，也可以继续点播电影、电视剧和经典歌曲。</p>
      </div>
      <div class="about-value-card">
        <h4>&#127987; 聚焦福建，综合扩展</h4>
        <p>Demo 以福建地方戏曲为核心，同时加入南音和经典影视。后续可以扩展全国戏曲和多种娱乐内容，逐步成为长辈专属的娱乐点播入口。</p>
      </div>
      <div class="about-value-card">
        <h4>&#128266; 从"搜索"升级为"点播"</h4>
        <p>普通网页让用户自己搜索，而这个作品更像一个懂阿嬷说话方式的频道助手。它降低了使用门槛，也增强了家庭陪伴感。</p>
      </div>
    </div>

    <h3>&#128241; 使用场景</h3>
    <p>长辈在家用手机点戏 / 子女陪老人一起找节目 / 孙辈帮阿嬷录入习惯叫法 / 社区养老活动播放地方戏曲 / 老年大学、文化馆做非遗展示 / 乡村文化站做地方戏曲数字化体验 / 家庭电视或平板作为长辈娱乐入口使用。</p>

    <h3>&#128150; 社会价值</h3>
    <p>《阿嬷的频道》关注的是数字时代里一群容易被忽略的用户：喜欢传统文化和日常娱乐，但不熟悉智能设备的长辈。它希望通过 AI 和网页技术，让老人更容易找到熟悉的乡音、熟悉的戏曲、熟悉的节目；也让年轻人重新看见福建地方戏曲和传统音乐的价值。这既是一个娱乐工具，也是一个面向长辈的<span class="highlight">公益型文化入口</span>。</p>

    <h3>&#128202; 后续规划</h3>
    <p>Demo 阶段先完成 8 个核心类目的点播体验。后续可以继续扩展：</p>
    <p><span class="highlight">更多福建戏曲</span>：北路戏、四平戏、梅林戏<br>
    <span class="highlight">更多全国戏曲</span>：越剧、黄梅戏、豫剧、粤剧、秦腔<br>
    <span class="highlight">更多福建非遗</span>：霍童线狮、畲族民歌、九鲤灯舞、拍胸舞、福州评话<br>
    <span class="highlight">更多娱乐节目</span>：小品、相声、电视剧、电影、音乐、舞蹈</p>
    <p>还可以接入真实语音识别、建立节目数据库、支持家庭成员远程帮长辈维护节目库、增加社区/文化馆版本、支持电视大屏模式。</p>

    <h3>&#128214; 社区提交文案</h3>
    <p style="background:rgba(212,168,83,0.08);padding:12px;border-radius:8px;border:1px solid rgba(212,168,83,0.15);font-size:0.88em;line-height:1.9;">
      《阿嬷的频道》是一个帮助老年人用方言语音找节目的网站。奶奶外婆想看莆仙戏、歌仔戏、南音、木偶戏，或者想听经典歌曲、看电视剧和电影时，只要说出想看的内容，系统就会自动理解意思并寻找合适节目，先显示图片让用户确认，再播放原声内容。这个创意想解决老年人不会打字、普通话发音不准、只会使用方言、怕点错广告、找不到原版内容的问题，让科技变得更简单、更温暖，也让家人和长辈有更多共同交流的话题。
    </p>

    <p style="text-align:center;color:var(--gold);font-size:1.1em;margin-top:20px;font-style:italic;">
      让长辈不用跨过复杂技术的门槛，也能轻松打开自己的频道。<br>让乡音被听见，让非遗被看见，也让每一次点播都成为一次陪伴。
    </p>

    <button class="about-close-btn" id="aboutCloseBtn">关 闭</button>
  </div>
</div>

<script>
// About modal
const aboutBtn = document.getElementById('aboutBtn');
const aboutOverlay = document.getElementById('aboutOverlay');
const aboutCloseBtn = document.getElementById('aboutCloseBtn');

aboutBtn.addEventListener('click', () => {
  aboutOverlay.classList.remove('hidden');
  document.body.style.overflow = 'hidden';
});

aboutCloseBtn.addEventListener('click', () => {
  aboutOverlay.classList.add('hidden');
  document.body.style.overflow = '';
});

aboutOverlay.addEventListener('click', (e) => {
  if (e.target === aboutOverlay) {
    aboutOverlay.classList.add('hidden');
    document.body.style.overflow = '';
  }
});
</script>

<!-- ===== Puxian Input Modal ===== -->
<div class="about-modal-overlay hidden" id="puxianInputOverlay">
  <div class="about-modal" style="max-width:520px;">
    <h2>&#127908; 录入莆仙话</h2>
    <p class="about-subtitle">输入中文名称，然后录入对应的莆仙话发音</p>
    
    <div style="margin-bottom:16px;">
      <label style="color:var(--gold);font-size:0.9em;">中文名称（对应频道库中的节目名）：</label>
      <input type="text" id="puxianChineseInput" placeholder="如：春草闯堂" style="width:100%;padding:10px;border-radius:8px;border:1px solid rgba(212,168,83,0.3);background:rgba(255,248,232,0.9);color:#2A1A0E;font-size:1em;margin-top:6px;font-family:'Noto Serif SC','Songti SC','SimSun','Microsoft YaHei',serif;box-sizing:border-box;" />
    </div>
    
    <div style="margin-bottom:16px;">
      <label style="color:var(--gold);font-size:0.9em;">莆仙话发音（用普通话拼音或近似字标注）：</label>
      <input type="text" id="puxianDialectInput" placeholder="如：春草闯堂 → cun cao cong dong" style="width:100%;padding:10px;border-radius:8px;border:1px solid rgba(212,168,83,0.3);background:rgba(255,248,232,0.9);color:#2A1A0E;font-size:1em;margin-top:6px;font-family:'Noto Serif SC','Songti SC','SimSun','Microsoft YaHei',serif;box-sizing:border-box;" />
    </div>

    <div style="display:flex;align-items:center;gap:8px;margin-top:8px;flex-wrap:wrap;">
      <button id="puxianDictMicBtn" style="width:56px;height:56px;border-radius:50%;border:2px solid var(--gold);background:transparent;color:var(--gold);font-size:1.5em;cursor:pointer;display:flex;align-items:center;justify-content:center;" title="\u6309\u4f4f\u8bf4\u8bdd">&#127908;</button>
      <div id="puxianDictPinyin" style="flex:1;font-size:clamp(14px,3vw,17px);color:var(--text-muted);min-height:28px;line-height:1.5;">点击麦克风录入方言发音，系统自动显示拼音近似</div>
    </div>
    
    <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
      <button id="puxianSaveBtn" style="padding:10px 28px;border-radius:25px;border:2px solid var(--gold);background:linear-gradient(135deg,var(--gold),#C49A3A);color:var(--bg-dark);font-weight:700;font-size:1em;cursor:pointer;font-family:'Noto Serif SC','Songti SC','SimSun','Microsoft YaHei',serif;">保存词条</button>
      <button id="puxianMatchBtn" style="padding:10px 28px;border-radius:25px;border:2px solid var(--gold);background:transparent;color:var(--gold);font-size:1em;cursor:pointer;font-family:'Noto Serif SC','Songti SC','SimSun','Microsoft YaHei',serif;">匹配节目</button>
    </div>
    
    <div id="puxianInputStatus" style="margin-top:12px;text-align:center;color:var(--text-muted);font-size:0.85em;"></div>
    
    <div style="margin-top:20px;border-top:1px solid rgba(212,168,83,0.15);padding-top:16px;">
      <label style="color:var(--gold);font-size:0.9em;">已录入的莆仙话词条（保存在本地）：</label>
      <div id="puxianCustomList" style="max-height:150px;overflow-y:auto;margin-top:8px;font-size:0.85em;"></div>
    </div>
    
    <button class="about-close-btn" id="puxianInputCloseBtn">关 闭</button>
  </div>
</div>

<script>
// Puxian dialect custom input
const puxianInputBtn = document.getElementById('puxianInputBtn');
const puxianInputOverlay = document.getElementById('puxianInputOverlay');
const puxianInputCloseBtn = document.getElementById('puxianInputCloseBtn');
const puxianSaveBtn = document.getElementById('puxianSaveBtn');
const puxianMatchBtn = document.getElementById('puxianMatchBtn');
const puxianInputStatus = document.getElementById('puxianInputStatus');
const puxianCustomList = document.getElementById('puxianCustomList');

// Load custom entries from localStorage
let customPuxianDict = JSON.parse(localStorage.getItem('customPuxianDict') || '{}');
Object.assign(puxianDict, customPuxianDict);

puxianInputBtn.addEventListener('click', () => {
  puxianInputOverlay.classList.remove('hidden');
  document.body.style.overflow = 'hidden';
  refreshCustomList();
});

puxianInputCloseBtn.addEventListener('click', () => {
  puxianInputOverlay.classList.add('hidden');
  document.body.style.overflow = '';
});

puxianInputOverlay.addEventListener('click', (e) => {
  if (e.target === puxianInputOverlay) {
    puxianInputOverlay.classList.add('hidden');
    document.body.style.overflow = '';
  }
});

setupDialectDictMic({
  buttonId: 'puxianDictMicBtn',
  statusId: 'puxianDictPinyin',
  dialectInputId: 'puxianDialectInput',
  chineseInputId: 'puxianChineseInput'
});

puxianSaveBtn.addEventListener('click', () => {
  const chinese = document.getElementById('puxianChineseInput').value.trim();
  const dialect = document.getElementById('puxianDialectInput').value.trim();
  if (!chinese || !dialect) {
    puxianInputStatus.textContent = '请填写中文名称和莆仙话发音';
    puxianInputStatus.style.color = '#FF6B6B';
    return;
  }
  customPuxianDict[dialect] = chinese;
  puxianDict[dialect] = chinese;
  localStorage.setItem('customPuxianDict', JSON.stringify(customPuxianDict));
  puxianInputStatus.textContent = '已保存："' + dialect + '" → "' + chinese + '"';
  puxianInputStatus.style.color = '#4CAF50';
  document.getElementById('puxianChineseInput').value = '';
  document.getElementById('puxianDialectInput').value = '';
  refreshCustomList();
});

puxianMatchBtn.addEventListener('click', () => {
  const chinese = document.getElementById('puxianChineseInput').value.trim();
  if (!chinese) {
    puxianInputStatus.textContent = '请先输入中文名称';
    puxianInputStatus.style.color = '#FF6B6B';
    return;
  }
  // Search in operaDB
  const found = operaDB.find(opera => opera.title === chinese || opera.title.includes(chinese));
  if (found) {
    puxianInputStatus.innerHTML = '找到节目：<strong style="color:var(--gold);">' + found.title + '</strong>（' + found.category + '）';
    puxianInputStatus.style.color = '#4CAF50';
  } else {
    puxianInputStatus.textContent = '未找到匹配的节目：' + chinese;
    puxianInputStatus.style.color = '#FF6B6B';
  }
});

function refreshCustomList() {
  puxianCustomList.innerHTML = '';
  const entries = Object.entries(customPuxianDict);
  if (entries.length === 0) {
    puxianCustomList.innerHTML = '<span style="color:var(--text-muted);">暂无自定义词条</span>';
    return;
  }
  entries.forEach(([dialect, chinese]) => {
    const item = document.createElement('div');
    item.style.cssText = 'padding:6px 8px;border-bottom:1px solid rgba(212,168,83,0.1);display:flex;justify-content:space-between;align-items:center;';
    item.innerHTML = '<span><span style="color:var(--gold);">' + escapeHtml(dialect) + '</span> → ' + escapeHtml(chinese) + '</span><button style="background:none;border:none;color:#FF6B6B;cursor:pointer;font-size:0.8em;padding:2px 6px;" type="button">删除</button>';
    item.querySelector('button').addEventListener('click', () => {
      delete customPuxianDict[dialect];
      delete puxianDict[dialect];
      localStorage.setItem('customPuxianDict', JSON.stringify(customPuxianDict));
      refreshCustomList();
    });
    puxianCustomList.appendChild(item);
  });
}

// Inject custom dict into translatePuxian function
const origTranslatePuxian = typeof translatePuxian === 'function' ? translatePuxian : null;
if (origTranslatePuxian) {
  window.translatePuxian = function(input) {
    // First apply custom dict
    let modified = input;
    for (const [dialect, chinese] of Object.entries(customPuxianDict)) {
      modified = modified.split(dialect).join(chinese);
    }
    // Then apply built-in dict
    if (modified !== input) {
      const result = origTranslatePuxian(modified);
      return result;
    }
    return origTranslatePuxian(input);
  };
}
</script>

<!-- ===== Minnan (闽南话) Input Modal ===== -->
<div class="about-modal-overlay hidden" id="minnanInputOverlay">
  <div class="about-modal" style="max-width:520px;">
    <h2>&#127908; 录入闽南话</h2>
    <p class="about-subtitle">输入中文名称，然后录入对应的闽南话发音</p>

    <div style="margin-bottom:16px;">
      <label style="color:var(--gold);font-size:0.9em;">中文名称（对应频道库中的节目名）：</label>
      <input type="text" id="minnanChineseInput" placeholder="如：陈三五娘" style="width:100%;padding:10px;border-radius:8px;border:1px solid rgba(212,168,83,0.3);background:rgba(255,248,232,0.9);color:#2A1A0E;font-size:1em;margin-top:6px;font-family:'Noto Serif SC','Songti SC','SimSun','Microsoft YaHei',serif;box-sizing:border-box;" />
    </div>

    <div style="margin-bottom:16px;">
      <label style="color:var(--gold);font-size:0.9em;">闽南话发音（用普通话拼音或近似字标注）：</label>
      <input type="text" id="minnanDialectInput" placeholder="如：陈三五娘 → tan sam ngoo nong" style="width:100%;padding:10px;border-radius:8px;border:1px solid rgba(212,168,83,0.3);background:rgba(255,248,232,0.9);color:#2A1A0E;font-size:1em;margin-top:6px;font-family:'Noto Serif SC','Songti SC','SimSun','Microsoft YaHei',serif;box-sizing:border-box;" />
    </div>

    <div style="display:flex;align-items:center;gap:8px;margin-top:8px;flex-wrap:wrap;">
      <button id="minnanDictMicBtn" style="width:56px;height:56px;border-radius:50%;border:2px solid var(--gold);background:transparent;color:var(--gold);font-size:1.5em;cursor:pointer;display:flex;align-items:center;justify-content:center;" title="\u6309\u4f4f\u8bf4\u8bdd">&#127908;</button>
      <div id="minnanDictPinyin" style="flex:1;font-size:clamp(14px,3vw,17px);color:var(--text-muted);min-height:28px;line-height:1.5;">点击麦克风录入方言发音，系统自动显示拼音近似</div>
    </div>

    <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
      <button id="minnanSaveBtn" style="padding:10px 28px;border-radius:25px;border:2px solid var(--gold);background:linear-gradient(135deg,var(--gold),#C49A3A);color:var(--bg-dark);font-weight:700;font-size:1em;cursor:pointer;font-family:'Noto Serif SC','Songti SC','SimSun','Microsoft YaHei',serif;">保存词条</button>
      <button id="minnanMatchBtn" style="padding:10px 28px;border-radius:25px;border:2px solid var(--gold);background:transparent;color:var(--gold);font-size:1em;cursor:pointer;font-family:'Noto Serif SC','Songti SC','SimSun','Microsoft YaHei',serif;">匹配节目</button>
    </div>

    <div id="minnanInputStatus" style="margin-top:12px;text-align:center;color:var(--text-muted);font-size:0.85em;"></div>

    <div style="margin-top:20px;border-top:1px solid rgba(212,168,83,0.15);padding-top:16px;">
      <label style="color:var(--gold);font-size:0.9em;">已录入的闽南话词条（保存在本地）：</label>
      <div id="minnanCustomList" style="max-height:150px;overflow-y:auto;margin-top:8px;font-size:0.85em;"></div>
    </div>

    <button class="about-close-btn" id="minnanInputCloseBtn">关 闭</button>
  </div>
</div>

<script>
// Minnan dialect custom input
const minnanInputBtn = document.getElementById('minnanInputBtn');
const minnanInputOverlay = document.getElementById('minnanInputOverlay');
const minnanInputCloseBtn = document.getElementById('minnanInputCloseBtn');
const minnanSaveBtn = document.getElementById('minnanSaveBtn');
const minnanMatchBtn = document.getElementById('minnanMatchBtn');
const minnanInputStatus = document.getElementById('minnanInputStatus');
const minnanCustomList = document.getElementById('minnanCustomList');

// Load custom entries from localStorage
let customMinnanDict = JSON.parse(localStorage.getItem('customMinnanDict') || '{}');
Object.assign(minnanDict, customMinnanDict);

minnanInputBtn.addEventListener('click', () => {
  minnanInputOverlay.classList.remove('hidden');
  document.body.style.overflow = 'hidden';
  refreshMinnanCustomList();
});

minnanInputCloseBtn.addEventListener('click', () => {
  minnanInputOverlay.classList.add('hidden');
  document.body.style.overflow = '';
});

minnanInputOverlay.addEventListener('click', (e) => {
  if (e.target === minnanInputOverlay) {
    minnanInputOverlay.classList.add('hidden');
    document.body.style.overflow = '';
  }
});

setupDialectDictMic({
  buttonId: 'minnanDictMicBtn',
  statusId: 'minnanDictPinyin',
  dialectInputId: 'minnanDialectInput',
  chineseInputId: 'minnanChineseInput'
});

minnanSaveBtn.addEventListener('click', () => {
  const chinese = document.getElementById('minnanChineseInput').value.trim();
  const dialect = document.getElementById('minnanDialectInput').value.trim();
  if (!chinese || !dialect) {
    minnanInputStatus.textContent = '请填写中文名称和闽南话发音';
    minnanInputStatus.style.color = '#FF6B6B';
    return;
  }
  customMinnanDict[dialect] = chinese;
  minnanDict[dialect] = chinese;
  localStorage.setItem('customMinnanDict', JSON.stringify(customMinnanDict));
  minnanInputStatus.textContent = '已保存："' + dialect + '" → "' + chinese + '"';
  minnanInputStatus.style.color = '#4CAF50';
  document.getElementById('minnanChineseInput').value = '';
  document.getElementById('minnanDialectInput').value = '';
  refreshMinnanCustomList();
});

minnanMatchBtn.addEventListener('click', () => {
  const chinese = document.getElementById('minnanChineseInput').value.trim();
  if (!chinese) {
    minnanInputStatus.textContent = '请先输入中文名称';
    minnanInputStatus.style.color = '#FF6B6B';
    return;
  }
  const found = operaDB.find(opera => opera.title === chinese || opera.title.includes(chinese));
  if (found) {
    minnanInputStatus.innerHTML = '找到节目：<strong style="color:var(--gold);">' + found.title + '</strong>（' + found.category + '）';
    minnanInputStatus.style.color = '#4CAF50';
  } else {
    minnanInputStatus.textContent = '未找到匹配的节目：' + chinese;
    minnanInputStatus.style.color = '#FF6B6B';
  }
});

function refreshMinnanCustomList() {
  minnanCustomList.innerHTML = '';
  const entries = Object.entries(customMinnanDict);
  if (entries.length === 0) {
    minnanCustomList.innerHTML = '<span style="color:var(--text-muted);">暂无自定义词条</span>';
    return;
  }
  entries.forEach(([dialect, chinese]) => {
    const item = document.createElement('div');
    item.style.cssText = 'padding:6px 8px;border-bottom:1px solid rgba(212,168,83,0.1);display:flex;justify-content:space-between;align-items:center;';
    item.innerHTML = '<span><span style="color:var(--gold);">' + escapeHtml(dialect) + '</span> → ' + escapeHtml(chinese) + '</span><button style="background:none;border:none;color:#FF6B6B;cursor:pointer;font-size:0.8em;padding:2px 6px;" type="button">删除</button>';
    item.querySelector('button').addEventListener('click', () => {
      delete customMinnanDict[dialect];
      delete minnanDict[dialect];
      localStorage.setItem('customMinnanDict', JSON.stringify(customMinnanDict));
      refreshMinnanCustomList();
    });
    minnanCustomList.appendChild(item);
  });
}

// Inject custom dict into translateMinnan function
const origTranslateMinnan = typeof translateMinnan === 'function' ? translateMinnan : null;
if (origTranslateMinnan) {
  window.translateMinnan = function(input) {
    // First apply custom dict
    let modified = input;
    for (const [dialect, chinese] of Object.entries(customMinnanDict)) {
      modified = modified.split(dialect).join(chinese);
    }
    // Then apply built-in dict
    return origTranslateMinnan(modified);
  };
}
</script>
</body>
