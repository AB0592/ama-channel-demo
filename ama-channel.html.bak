// 闽南话翻译引擎
function translateMinnan(input) {
  if (!input) return { translated: '', changed: false };

  const trimmed = input.trim();
  let translated = trimmed;
  let changed = false;

  // 整句匹配
  for (const [k, v] of Object.entries(minnanDict)) {
    if (translated.includes(k) && k === v) continue;
    if (translated.includes(k)) {
      translated = translated.replaceAll(k, v);
      if (v !== k) changed = true;
    }
  }

  // 逐字/逐词替换（按长度降序）
  const sortedKeys = Object.keys(minnanDict).sort((a, b) => b.length - a.length);
  for (const k of sortedKeys) {
    if (translated.includes(k)) {
      translated = translated.replaceAll(k, minnanDict[k]);
      if (minnanDict[k] !== k) changed = true;
    }
  }

  return { translated: translated.trim(), changed };
}

// =============================================
// 莆仙话翻译引擎
// =============================================
function translatePuxian(input) {
  if (!input) return { translated: '', changed: false };

  const trimmed = input.trim();
  let translated = trimmed;
  let changed = false;

  // 第一优先：整句匹配
  for (const [k, v] of Object.entries(puxianDict)) {
    if (translated.includes(k) && k === v) continue;
    if (translated.includes(k)) {
      translated = translated.replaceAll(k, v);
      if (v !== k) changed = true;
    }
  }

  // 第二优先：逐字/逐词替换（按长度降序，避免短词覆盖长词）
  const sortedKeys = Object.keys(puxianDict).sort((a, b) => b.length - a.length);
  for (const k of sortedKeys) {
    if (translated.includes(k)) {
      translated = translated.replaceAll(k, puxianDict[k]);
      if (puxianDict[k] !== k) changed = true;
    }
  }

  return { translated: translated.trim(), changed };
}

function normalizeSpokenQuery(input) {
  if (!input) return '';
  var text = String(input)
    .replace(/[，。！？、,.!?；;：:\s]/g, '')
    .replace(/^(阿嬷|阿妈|奶奶|外婆|老人家)?(我想|我要|我爱|想要|想|要|帮我|给我|替我|请帮我|请给我)?(看一下|听一下|看|听|播放|放一下|放|打开|找一下|找|点播|点一下|点)?/g, '')
    .replace(/(这个|一下|看看|听听|节目|视频|音频)$/g, '');

  var fixes = {
    // 莆仙戏
    '新品类': '新亭泪', '新品泪': '新亭泪', '新平泪': '新亭泪',
    '新听泪': '新亭泪', '新停泪': '新亭泪', '新亭类': '新亭泪',
    '新亭累': '新亭泪', '新庭泪': '新亭泪',
    '秋风词': '秋风辞',
    '状元乞丐': '状元与乞丐', '状元与乞丐': '状元与乞丐',
    '状员': '状元', '壮员': '状元', '状圆': '状元',
    '江梅飞': '江梅妃', '江美飞': '江梅妃',
    '春草闯唐': '春草闯堂', '春草闯汤': '春草闯堂',
    '春草窗堂': '春草闯堂',
    // 歌仔戏
    '陈三五娘': '陈三五娘', '陈三无娘': '陈三五娘',
    '梁山伯': '梁山伯与祝英台',
    '祝英台': '梁山伯与祝英台', '祝影台': '梁山伯与祝英台',
    '吕蒙正': '吕蒙正', '绿蒙正': '吕蒙正',
    '薛平贵': '薛平贵与王宝钏', '王宝钏': '薛平贵与王宝钏',
    '王金龙': '王金龙与苏三', '苏三': '王金龙与苏三',
    // 南音
    '八俊马': '八骏马', '八军马': '八骏马',
    '梅花操': '梅花操', '梅花草': '梅花操',
    '百鸟归巢': '百鸟归巢', '白鸟归巢': '百鸟归巢',
    '三千两金': '三千两金', '三钱两金': '三千两金',
    '直入花园': '直入花园', '只入花园': '直入花园',
    '小沙弥': '小沙弥下山', '小沙迷': '小沙弥下山',
    '驯猴': '驯猴', '训猴': '驯猴',
    '元宵乐': '元宵乐', '元霄乐': '元宵乐',
    // 木偶戏
    '木偶系': '木偶戏', '木偶戏': '木偶戏',
    '大名府': '大名府', '大民府': '大名府',
    '雷文春': '雷文春大花',
    '岳飞传': '岳飞传', '岳飞': '岳飞传',
    '猪八戒': '猪八戒娶亲',
    // 电视剧
    '射雕英雄': '射雕英雄传', '射雕': '射雕英雄传',
    '红楼梦': '红楼梦',
    '三国演义': '三国演义', '三国': '三国演义',
    '水浒传': '水浒传', '水浒': '水浒传',
    '西游记': '西游记', '西游': '西游记',
    // 音乐
    '东方红': '东方红',
    '没有共产党': '没有共产党就没有新中国',
    '打靶归来': '打靶归来', '打把归来': '打靶归来',
    '最炫民族风': '最炫民族风', '最悬民族风': '最炫民族风',
    '小苹果': '小苹果',
    // 电影
    '地道战': '地道战',
    '铁道游击队': '铁道游击队', '铁道': '铁道游击队',
    '英雄儿女': '英雄儿女', '英雄': '英雄儿女',
    '人到中年': '人到中年',
    '庐山恋': '庐山恋', '庐山': '庐山恋',
    // 通用误识别
    '春草': '春草闯堂',
    '状元': '状元与乞丐',
    '秋风': '秋风辞',
    '江梅': '江梅妃',
    '新亭': '新亭泪'
  };

  Object.keys(fixes).forEach(function(key) {
    if (text.indexOf(key) !== -1) {
      text = text.replaceAll(key, fixes[key]);
    }
  });

  return text.trim();
}

function getTranslatedSearchText(rawInput) {
  if (currentLang === 'chinese') {
    return { translated: rawInput, changed: false };
  }
  if (currentLang === 'minnanhua') {
    return translateMinnan(rawInput);
  }
  return translatePuxian(rawInput);
}

function buildSearchCandidates(rawInput) {
  var translatedInfo = getTranslatedSearchText(rawInput);
  var translated = translatedInfo.changed ? translatedInfo.translated : rawInput;
  var candidates = [
    translated,
    normalizeSpokenQuery(translated),
    rawInput,
    normalizeSpokenQuery(rawInput),
    toPinyinApprox(translated).replace(/\s+/g, ''),
    toPinyinApprox(rawInput).replace(/\s+/g, '')
  ];

  var seen = {};
  return candidates
    .map(function(item) { return (item || '').trim(); })
    .filter(function(item) {
      if (!item || seen[item]) return false;
      seen[item] = true;
      return true;
    });
}

function findBestVoiceMatches(rawInput) {
  var candidates = buildSearchCandidates(rawInput);
  var allResults = [];
  var seen = {};
  for (var i = 0; i < candidates.length; i++) {
    var results = searchOpera(candidates[i]);
    for (var j = 0; j < results.length; j++) {
      var title = results[j].title;
      if (!seen[title]) {
        seen[title] = true;
        allResults.push(results[j]);
      }
    }
  }
  return { query: candidates[0] || rawInput, results: allResults };
}

// =============================================
// 内嵌 SVG 海报图生成器
// =============================================
function generatePoster(title, category, color1, color2) {
  const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="200" height="130" viewBox="0 0 200 130">
    <defs>
      <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color:${color1}"/>
        <stop offset="100%" style="stop-color:${color2}"/>
      </linearGradient>
      <linearGradient id="shine" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" style="stop-color:rgba(255,255,255,0.15)"/>
        <stop offset="100%" style="stop-color:rgba(255,255,255,0)"/>
      </linearGradient>
    </defs>
    <rect width="200" height="130" rx="8" fill="url(#bg)"/>
    <rect width="200" height="130" rx="8" fill="url(#shine)"/>
    <text x="100" y="58" text-anchor="middle" fill="rgba(255,255,255,0.3)" font-size="36" font-family="serif">${category.charAt(0)}</text>
    <text x="100" y="95" text-anchor="middle" fill="white" font-size="15" font-weight="bold" font-family="'Noto Serif SC','Songti SC','SimSun','Microsoft YaHei',serif">${title.length > 7 ? title.substring(0,7) : title}</text>
    <text x="100" y="118" text-anchor="middle" fill="rgba(255,255,255,0.6)" font-size="10" font-family="'Noto Serif SC','Songti SC','SimSun','Microsoft YaHei',serif">${category}</text>
  </svg>`;
  return 'data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(svg)));
}

